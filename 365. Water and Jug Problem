class Solution {
    Set<Integer> visited = new HashSet<>();
    public boolean helper(int x, int y, int target, int total) {
        if(total == target)
            return true;
        if(visited.contains(total) || total < 0 || total > x + y)
            return false;
        
        visited.add(total);
        return (
            helper(x, y, target, total + x) ||
            helper(x, y, target, total - x) ||
            helper(x, y, target, total + y) ||
            helper(x, y, target, total - y)
        );
    }
    public boolean canMeasureWater(int x, int y, int target) {
        return helper(x, y, target, 0);
    }
}
