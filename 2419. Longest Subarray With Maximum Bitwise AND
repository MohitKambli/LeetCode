class Solution {
    public int longestSubarray(int[] nums) {
        int max = Integer.MIN_VALUE, n = nums.length, ans = 0, j = -1;
        for(int num : nums)
            max = Math.max(max, num);
        for(int i=0;i<n;i++) {
            if(nums[i] != max)
                j = i;
            ans = Math.max(ans, i - j);
        }
        return ans;
    }
}
