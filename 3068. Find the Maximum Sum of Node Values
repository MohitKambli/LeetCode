class Solution {
    public long maximumValueSum(int[] nums, int k, int[][] edges) {
        int n = nums.length;
        int[] delta = new int[n];
        long result = 0;
        for(int i=0;i<n;i++) {
            result += nums[i];
            delta[i] = (nums[i] ^ k) - nums[i];
        }
        Arrays.sort(delta);
        for(int i=n-1;i>=0;i-=2) {
            if(i == 0)
                break;
            int totalDelta = delta[i] + delta[i-1];
            if(totalDelta <= 0)
                break;
            result += totalDelta;
        }
        return result;
    }
}
