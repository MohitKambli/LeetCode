class Solution {
    public String longestCommonPrefix(String[] strs) {
        Arrays.sort(strs);
        String first = strs[0], last = strs[strs.length-1], ans = "";
        int len = Math.min(first.length(), last.length()), index = 0;
        while(index < len && first.charAt(index) == last.charAt(index)) {
            ans += first.charAt(index);
            index++;
        }
        return ans;
    }
}
