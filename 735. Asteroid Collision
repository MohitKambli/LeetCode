class Solution {
    public int[] asteroidCollision(int[] asteroids) {
        List<Integer> stack = new ArrayList<>();
        for(int asteroid : asteroids) {
            while(!stack.isEmpty() && asteroid < 0 && stack.get(stack.size()-1) > 0) {
                int diff = asteroid + stack.get(stack.size()-1);
                if(diff > 0) {
                    asteroid = 0;
                } else if(diff < 0) {
                    stack.remove(stack.size()-1);
                } else {
                    asteroid = 0;
                    stack.remove(stack.size()-1);
                }
            }
            if(asteroid != 0)
                stack.add(asteroid);
        }
        int n = stack.size(), i = 0;
        int[] ans = new int[n];
        for(int x : stack)
            ans[i++] = x;
        return ans;
    }
}
