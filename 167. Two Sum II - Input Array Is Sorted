class Solution {
    public int[] twoSum(int[] numbers, int target) {
        int left = 0, right = numbers.length-1;
        while(left < right) {
            int value = numbers[left] + numbers[right];
            if(target == value)
                return new int[]{left+1, right+1};
            if(target < value)
                right--;
            else
                left++;
        }
        return new int[]{-1, -1};
    }
}
