class Solution {
    public void helper(int index, int n, boolean[] visited, List<List<Integer>> rooms) {
        if(visited[index])
            return;
        
        visited[index] = true;
        for(int node : rooms.get(index))
            helper(node, n, visited, rooms);
    }
    public boolean canVisitAllRooms(List<List<Integer>> rooms) {
        int n = rooms.size();
        boolean[] visited = new boolean[n];
        helper(0, n, visited, rooms);
        for(boolean value : visited)
            if(!value)
                return false;
        return true;
    }
}
