class Solution {
    public void helper(int node, int n, boolean[] visited, List<List<Integer>> rooms) {
        if(visited[node])
            return;
        
        visited[node] = true;
        for(int adjNode : rooms.get(node))
            helper(adjNode, n, visited, rooms);
    }
    public boolean canVisitAllRooms(List<List<Integer>> rooms) {
        int n = rooms.size();
        boolean[] visited = new boolean[n];
        helper(0, n, visited, rooms);
        for(boolean value : visited)
            if(!value)
                return false;
        return true;
    }
}
