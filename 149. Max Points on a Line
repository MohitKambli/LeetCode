class Solution {
    public int maxPoints(int[][] points) {
        int n = points.length;
        int ans = 1;
        for(int i=0;i<n;i++) {
            for(int j=i+1;j<n;j++) {
                int count = 2;
                int dy_1 = points[j][1] - points[i][1];
                int dx_1 = points[j][0] - points[i][0];
                for(int k=0;k<n;k++) {
                    if(k != i && k != j) {
                        int dy_2 = points[k][1] - points[i][1];
                        int dx_2 = points[k][0] - points[i][0];
                        if((dy_1 * dx_2) == (dy_2 * dx_1))
                            count++;
                    }
                }
                ans = Math.max(ans, count);
            }
        }
        return ans;
    }
}
