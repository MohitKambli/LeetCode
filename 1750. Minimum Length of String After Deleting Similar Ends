class Solution {
    public int minimumLength(String s) {
        int left = 0, right = s.length()-1, n = s.length(), count = 0;
        while(left < right && s.charAt(left) == s.charAt(right)) {
            char chLeft = s.charAt(left);
            while(left <= right && s.charAt(left) == chLeft) {
                left++;
                count++;
            }
            char chRight = s.charAt(right);
            while(left <= right && s.charAt(right) == chRight) {
                right--;
                count++;
            }
        }
        return n - count;
    }
}
