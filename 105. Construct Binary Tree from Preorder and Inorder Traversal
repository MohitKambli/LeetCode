/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public TreeNode helper(int[] index, int start, int end, int[] preorder, int[] inorder) {
        if(start > end)
            return null;
        
        int nodeValue = preorder[index[0]];
        int i = start;
        for(;i<=end;i++)
            if(inorder[i] == nodeValue)
                break;
        index[0]++;
        TreeNode node = new TreeNode(nodeValue);
        node.left = helper(index, start, i-1, preorder, inorder);
        node.right = helper(index, i+1, end, preorder, inorder);
        return node;
    }
    public TreeNode buildTree(int[] preorder, int[] inorder) {
        return helper(new int[]{0}, 0, inorder.length-1, preorder, inorder);
    }
}
