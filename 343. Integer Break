class Solution {
    public int helper(int n, int[] dp) {
        if(n == 0)
            return 1;
        if(dp[n] != -1)
            return dp[n];

        int result = 1;
        for(int i=1;i<n;i++) {
            int prod = i * Math.max((n-i), helper(n-i, dp));
            result = Math.max(result, prod);
        }
        return dp[n] = result;
    }
    public int integerBreak(int n) {
        int[] dp = new int[n+1];
        Arrays.fill(dp, -1);
        return helper(n, dp);
    }
}
