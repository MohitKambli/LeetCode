class Solution {
    public char findTheDifference(String s, String t) {
        int[] alphabets = new int[26];
        for(char ch : t.toCharArray())
            alphabets[ch - 'a']++;
        for(char ch : s.toCharArray())
            alphabets[ch - 'a']--;
        for(int i=0;i<26;i++)
            if(alphabets[i] == 1)
                return (char)(i + 'a');
        return '0';
    }
}
