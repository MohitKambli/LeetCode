class Solution {
    public int lengthOfLongestSubstring(String s) {
        int n = s.length(), ans = 0, i = 0, j = 0;
        Set<Character> set = new HashSet<>();
        while(i < n) {
            char ch = s.charAt(i);
            if(!set.contains(ch)) {
                set.add(ch);
                ans = Math.max(ans, i - j + 1);
                i++;
            } else {
                set.remove(s.charAt(j++));
            }
        }
        return ans;
    }
}
