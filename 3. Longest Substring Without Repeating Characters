class Solution {
    public int lengthOfLongestSubstring(String s) {
        int n = s.length(), max = 0, l = 0;
        Set<Character> set = new HashSet<>();
        for(int r = 0;r<n;r++) {
            char ch = s.charAt(r);
            if(!set.contains(ch))
                max = Math.max(max, r - l + 1);
            else {
                while(set.contains(ch))
                    set.remove(s.charAt(l++));
            }
            set.add(ch);
        }
        return max;
    }
}
