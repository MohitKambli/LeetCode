class Solution {
    public int lengthOfLongestSubstring(String s) {
        int n = s.length(), i = 0, j = 0, ans = 0;
        Set<Character> set = new HashSet<>();
        while(j < n) {
            char ch = s.charAt(j);
            if(!set.contains(ch)) {
                set.add(ch);
                ans = Math.max(ans, j - i + 1);
                j++;
            } else {
                set.remove(s.charAt(i++));
            }
        }
        return ans;
    }
}
