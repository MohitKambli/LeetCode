class Solution {
    public int lengthOfLongestSubstring(String s) {
        int n = s.length();
        int ans = 0, j = 0;
        Set<Character> set = new HashSet<>();
        for(int i=0;i<n;i++) {
            char temp = s.charAt(i);
            if(!set.contains(temp)) {
                ans = Math.max(ans, i-j+1);
            } else {
                while(set.contains(temp))
                    set.remove(s.charAt(j++));
            }
            set.add(temp);
        }
        return ans;
    }
}
