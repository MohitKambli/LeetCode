class Solution {
    public void helper(int i, int j, int m, int n, int[][] grid, boolean[][] visited, int[] count) {
        if(i < 0 || i == m || j < 0 || j == n || grid[i][j] == 0 || visited[i][j])
            return;
        
        visited[i][j] = true;
        count[0]++;
        helper(i-1, j, m, n, grid, visited, count);
        helper(i+1, j, m, n, grid, visited, count);
        helper(i, j-1, m, n, grid, visited, count);
        helper(i, j+1, m, n, grid, visited, count);
    }
    public int maxAreaOfIsland(int[][] grid) {
        int m = grid.length, n = grid[0].length, ans = 0;
        boolean[][] visited = new boolean[m][n];
        for(int i=0;i<m;i++) {
            for(int j=0;j<n;j++) {
                if(grid[i][j] == 1 && !visited[i][j]) {
                    int[] count = new int[]{0};
                    helper(i, j, m, n, grid, visited, count);
                    ans = Math.max(ans, count[0]);
                }
            }
        }
        return ans;
    }
}
