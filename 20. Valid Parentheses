class Solution {
    public boolean isValid(String s) {
        int n = s.length();
        List<Character> stack = new ArrayList<>();
        for(int i=0;i<n;i++) {
            char ch = s.charAt(i);
            if(ch == '(' || ch == '[' || ch == '{') {
                stack.add(ch);
                continue;
            } else {
                if(!stack.isEmpty()) {
                    char c = stack.remove(stack.size()-1);
                    if(ch == ')' && (c == '[' || c == '{'))
                        return false;
                    if(ch == ']' && (c == '(' || c == '{'))
                        return false;
                    if(ch == '}' && (c == '[' || c == '('))
                        return false;
                } else {
                    return false;
                }
            }
        }
        return stack.isEmpty();
    }
}
