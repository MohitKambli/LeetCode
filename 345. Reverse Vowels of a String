class Solution {
    public String reverseVowels(String s) {
        StringBuilder sb = new StringBuilder(s);
        int l=0, r = sb.length()-1;
        String vowels = "aeiouAEIOU";
        while(l < r) {
            if(vowels.contains(Character.toString(sb.charAt(l)))) {
                if(vowels.contains(Character.toString(sb.charAt(r)))) {
                    char temp = sb.charAt(l);
                    sb.setCharAt(l, sb.charAt(r));
                    sb.setCharAt(r, temp);
                    l++;
                    r--;
                } else {
                    r--;
                }
            } else {
                l++;
            }
        }
        return sb.toString();
    }
}
