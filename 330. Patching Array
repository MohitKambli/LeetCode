class Solution {
    public int minPatches(int[] nums, int n) {
        int len = nums.length, patches = 0, index = 0;
        long maxReach = 0;
        while(maxReach < n) {
            if(index < len && nums[index] <= maxReach + 1)
                maxReach += nums[index++];
            else {
                maxReach += (maxReach + 1);
                patches++;
            }
        }
        return patches;
    }
}
