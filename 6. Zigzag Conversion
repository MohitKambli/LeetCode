class Solution {
    public String convert(String s, int numRows) {
        if(numRows == 1)
            return s;
        String res = "";
        int n = s.length();
        for(int i=0;i<numRows;i++) {
            int increment = 2 * (numRows - 1);
            for(int j=i;j<n;j+=increment) {
                res += s.charAt(j);
                int specialIndex = (j + increment) - (2 * i);
                if(i > 0 && i < numRows-1 && specialIndex < n)
                    res += s.charAt(specialIndex);
            }
        }
        return res;
    }
}
