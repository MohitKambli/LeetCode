class Solution {
    public int helper(int i, int j, int[][] dp) {
        if(i == 0 && j == 0)
            return 1;
        if(i < 0 || j < 0)
            return 0;
        if(dp[i][j] != -1)
            return dp[i][j];

        int up = helper(i-1, j, dp);
        int left = helper(i, j-1, dp);
        return dp[i][j] = up + left;
    }
    public int uniquePaths(int m, int n) {
        int[][] dp = new int[m][n];

        // Recursion
        /*for(int[] arr : dp)
            Arrays.fill(arr, -1);
        return helper(m-1, n-1, dp);*/

        // Tabulation
        for(int[] arr : dp)
            Arrays.fill(arr, 1);
        dp[0][0] = 1;
        for(int i=1;i<m;i++) {
            for(int j=1;j<n;j++) {
                int up = 0;
                if(i > 0)
                    up = dp[i-1][j];
                int left = 0;
                if(j > 0)
                    left = dp[i][j-1];
                dp[i][j] = up + left;
            }
        }
        return dp[m-1][n-1];
    }
}
