class Solution {
    public int numSubarrayProductLessThanK(int[] nums, int k) {
        int prod = 1, j = 0, n = nums.length, count = 0;
        for(int i=0;i<n;i++) {
            prod *= nums[i];
            while(j <= i && prod >= k)
                prod /= nums[j++];
            count += (i - j + 1);
        }
        return count;
    }
}
