class Solution {
    public void helper(int openCount, int closeCount, String temp, int n, List<String> ans) {
        if(openCount == n && closeCount == n) {
            ans.add(temp);
            return;
        }

        if(openCount < n) {
            temp += "(";
            helper(openCount+1, closeCount, temp, n, ans);
            temp = temp.substring(0, temp.length()-1);
        }
        if(closeCount < openCount) {
            temp += ")";
            helper(openCount, closeCount+1, temp, n, ans);
            temp = temp.substring(0, temp.length()-1);
        }
    }
    public List<String> generateParenthesis(int n) {
        List<String> ans = new ArrayList<>();
        helper(0, 0, "", n, ans);
        return ans;
    }
}
