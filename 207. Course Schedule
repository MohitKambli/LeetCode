class Solution {
    public boolean helper(int n, Map<Integer, List<Integer>> adj, int[] degree) {
        List<Integer> queue = new ArrayList<>();
        int count = 0;
        for(int i=0;i<n;i++) {
            if(degree[i] == 0) {
                count++;
                queue.add(i);
            }
        }
        while(!queue.isEmpty()) {
            int node = queue.remove(0);
            if(adj.get(node) != null) {
                for(int x : adj.get(node)) {
                    degree[x]--;
                    if(degree[x] == 0) {
                        count++;
                        queue.add(x);
                    }
                }
            }
        }
        return count == n;
    }
    public boolean canFinish(int numCourses, int[][] prerequisites) {
        Map<Integer, List<Integer>> adj = new HashMap<>();
        int[] degree = new int[numCourses];
        for(int[] edge : prerequisites) {
            int u = edge[0];
            int v = edge[1];
            if(!adj.containsKey(v)) {
                List<Integer> arr = new ArrayList<>();
                arr.add(u);
                adj.put(v, arr);
            } else {
                adj.get(v).add(u);
            }
            degree[u]++;
        }
        return helper(numCourses, adj, degree);
    }
}
