class Solution {
    public int helper(int i, int j, int m, int n, int[][] matrix, int[][] dp) {
        if(j < 0 || j > n-1)
            return 20000;
        if(i == 0)
            return matrix[0][j];
        if(dp[i][j] != -1)
            return dp[i][j];

        int leftDiagonal = helper(i-1, j-1, m, n, matrix, dp);
        int up = helper(i-1, j, m, n, matrix, dp);
        int rightDiagonal = helper(i-1, j+1, m, n, matrix, dp);
        return dp[i][j] = matrix[i][j] + Math.min(leftDiagonal, Math.min(up, rightDiagonal));
    }
    public int minFallingPathSum(int[][] matrix) {
        int m = matrix.length, n = matrix[0].length, min = Integer.MAX_VALUE;
        int[][] dp = new int[m][n];
        // Recursion
        /*for(int[] arr : dp)
            Arrays.fill(arr, -1);
        for(int i=0;i<n;i++)
            min = Math.min(min, helper(m-1, i, m, n, matrix, dp));
        return min;*/

        // Tabulation
        for(int j=0;j<n;j++)
            dp[0][j] = matrix[0][j];
        for(int i=1;i<m;i++) {
            for(int j=0;j<n;j++) {
                int leftDiagonal = matrix[i][j];
                if(j-1 >= 0)
                    leftDiagonal += dp[i-1][j-1];
                else
                    leftDiagonal = Integer.MAX_VALUE;
                int up = matrix[i][j] + dp[i-1][j];
                int rightDiagonal = matrix[i][j];
                if(j+1 < n)
                    rightDiagonal += dp[i-1][j+1];
                else
                    rightDiagonal = Integer.MAX_VALUE;
                dp[i][j] = Math.min(leftDiagonal, Math.min(up, rightDiagonal));
            }
        }
        int ans = dp[m-1][0];
        for(int i=1;i<n;i++)
            ans = Math.min(ans, dp[m-1][i]);
        return ans;
    }
}
