class Solution {
    public void helper(int i, int j, int m, int n, boolean[][] visited, int[][] grid) {
        if(i < 0 || i == m || j < 0 || j == n || visited[i][j] || grid[i][j] == 0)
            return;
        
        if(grid[i][j] == 1) {
            visited[i][j] = true;
            grid[i][j] = -1;
            helper(i+1, j, m, n, visited, grid);
            helper(i-1, j, m, n, visited, grid);
            helper(i, j+1, m, n, visited, grid);
            helper(i, j-1, m, n, visited, grid);
        }
    }
    public int numEnclaves(int[][] grid) {
        int m = grid.length, n = grid[0].length;
        boolean[][] visited = new boolean[m][n];
        for(int i=0;i<n;i++)
            if(grid[0][i] == 1) 
                helper(0, i, m, n, visited, grid);

        for(int i=0;i<n;i++)
            if(grid[m-1][i] == 1)
                helper(m-1, i, m, n, visited, grid);

        for(int i=0;i<m;i++)
            if(grid[i][0] == 1)
                helper(i, 0, m, n, visited, grid);

        for(int i=0;i<m;i++)
            if(grid[i][n-1] == 1)
                helper(i, n-1, m, n, visited, grid);
        
        int count = 0;
        for(int i=0;i<m;i++) {
            for(int j=0;j<n;j++) {
                if(grid[i][j] == 1) {
                    count++;
                }
            }
        }
        return count;
    }
}
