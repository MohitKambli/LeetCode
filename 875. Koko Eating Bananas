class Solution {
    public boolean helper(int mid, int h, int[] piles) {
        int count = 0;
        for(int pile : piles) {
            count += pile / mid;
            if(pile % mid != 0)
                count++;
        }
        return count <= h;
    }
    public int minEatingSpeed(int[] piles, int h) {
        int max = 0;
        for(int pile : piles)
            max = Math.max(max, pile);
        int left = 1, right = max;
        while(left < right) {
            int mid = left + (right - left) / 2;
            if(helper(mid, h, piles))
                right = mid;
            else
                left = mid + 1;
        }
        return right;
    }
}
