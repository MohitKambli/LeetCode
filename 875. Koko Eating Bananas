class Solution {
    public boolean helper(int[] piles, int count, int h) {
        int ans = 0;
        for(int pile : piles) {
            ans += pile / count;
            if(pile % count != 0)
                ans++;
        }
        return ans <= h;
    }
    public int minEatingSpeed(int[] piles, int h) {
        int n = piles.length, left = 1, max = -1;
        for(int pile : piles)
            max = Math.max(max, pile);
        int right = max;
        while(left < right) {
            int mid = left + (right - left) / 2;
            if(helper(piles, mid, h))
                right = mid;
            else
                left = mid + 1;
        }
        return right;
    }
}
